Configs: {
	BrekotkinConfig: {
		DisplayName: Настройки Дмитрия Брекоткина

		ChanceDenominator: {
			Label: Шанс появления (1 из X тиков)
			Tooltip:
				'''
				Чем меньше число, тем чаще появляется Дмитрий. 
